.DS_Store

# Local editor state
.obsidian/workspace.json

# Local trash / scratch files
.trash/

# Python caches
__pycache__/
*.py[cod]

# Generated BG3 save extracts and indexes
tools/current-save/
tools/save-extract/
tools/save-index/

# Bundled external tooling
tools/Packed/

# yt-dlp metadata contains volatile, expiring URLs. Keep transcripts instead.
tools/video-transcripts/*.info.json

# Manual savegame copies. Large binaries, and sync_latest_save.py reads the
# Steam userdata dir directly rather than this folder.
saves/

# Source archive for tools/Packed/, which is itself ignored above.
tools/ExportTool-*.zip

# Session history and hook logs
.remember/

# Local-only permissions
.claude/settings.local.json
