.DS_Store

# Local editor state
.obsidian/workspace.json

# Local trash / scratch files
.trash/

# Python caches
__pycache__/
*.py[cod]

# Generated BG3 save extracts and indexes
tools/current-save/
tools/save-extract/
tools/save-index/

# Bundled external tooling
tools/Packed/

# yt-dlp metadata contains volatile, expiring URLs. Keep transcripts instead.
tools/video-transcripts/*.info.json

# Savegame mirrors copied by sync_latest_save.py. Large local binaries.
saves/

# Source archive for tools/Packed/, which is itself ignored above.
tools/ExportTool-*.zip

# Session history and hook logs
.remember/

# Local-only permissions
.claude/settings.local.json

# Generated site (rebuild with scripts/build_site.py; published by CI)
site/

# Real in-game journal text extracted from the player's game files.
# Copyrighted Larian content — generated locally by tools/extract_journal_text.py.
tools/journal-text/
# journal.local.md holds the real in-game journal prose (copyrighted); the
# public journal.md keeps readable titles only.
journal.local.md
